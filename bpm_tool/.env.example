# Copy this file to .env and fill in your Cloudflare R2 details.
# These keys are only used by the pipeline (server-side).
# Never commit .env or expose these keys in the mobile app.

# Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key

# The bucket name you created in R2
R2_BUCKET=noya-audio

# Public base URL — shown after enabling public access on the bucket
# Format: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
